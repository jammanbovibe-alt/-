rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rooms:
    // - Teachers can create if signed in
    // - Anyone (including student) can read to join the room using code
    match /rooms/{roomId} {
      allow create: if isSignedIn();
      allow read: if true;
      allow update: if isSignedIn() && request.auth.uid == resource.data.teacher_id;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.teacher_id;
    }

    // Submissions (Tiptap notes and AI dialogues):
    // - Students can create and update their notes/chat history
    // - Teachers can read all submissions for monitoring
    match /submissions/{submissionId} {
      allow create, update: if true; // Allows anonymous student session creation and subsequent chat edits
      allow read: if true; // Allows real-time reading by teachers for class dashboards
    }
  }
}
